# このファイルをコピーして .env を作成してください: cp .env.example .env

# Rails のセッション暗号化キー
# 生成方法: docker-compose run --rm rails_kozuchi rails secret
SECRET_KEY_BASE=your_secret_key_base_here

# PostgreSQL の接続設定
# KOZUCHI_DATABASE_PASSWORD は Rails アプリと PostgreSQL コンテナで共用します
KOZUCHI_DATABASE_PASSWORD=your_database_password_here
POSTGRES_DB=your_database_name_here
POSTGRES_USER=your_database_user_here

# HTTPS(SSL) を使用する場合は以下も設定してください（KOZUCHI_SSL=true 時に必要）
# Let's Encrypt の証明書パスを指定します
SSL_KEY_PATH=/etc/letsencrypt/live/your.domain.example.com/privkey.pem
SSL_CERT_PATH=/etc/letsencrypt/live/your.domain.example.com/fullchain.pem
